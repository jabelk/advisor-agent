# Finance Agent Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#   chmod 600 .env

# --- Required (Paper Trading) ---
# Alpaca paper trading API key ID
ALPACA_PAPER_API_KEY=
# Alpaca paper trading secret key
ALPACA_PAPER_SECRET_KEY=

# --- Optional (Live Trading) ---
# Alpaca live trading API key ID (only set when ready for live trading)
# ALPACA_LIVE_API_KEY=
# Alpaca live trading secret key
# ALPACA_LIVE_SECRET_KEY=

# --- Research Data Sources ---
# Anthropic API key for LLM analysis (required for research)
ANTHROPIC_API_KEY=
# SEC EDGAR identity string (required, format: "Name email@example.com")
EDGAR_IDENTITY=
# Finnhub API key for market signals (optional, free tier available)
# FINNHUB_API_KEY=
# EarningsCall.biz API key for earnings call transcripts (optional)
# EARNINGSCALL_API_KEY=
# Stratechery authenticated RSS feed URL (optional, requires subscription)
# STRATECHERY_FEED_URL=
# AssemblyAI API key for podcast transcription (optional)
# ASSEMBLYAI_API_KEY=

# --- Optional Settings ---
# Trading mode: "paper" (default) or "live"
TRADING_MODE=paper
# Path to SQLite database file
DB_PATH=data/finance_agent.db
# Directory for raw research documents (default: research_data/)
RESEARCH_DATA_DIR=research_data/
# Python logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
